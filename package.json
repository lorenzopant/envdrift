{
	"name": "@lorenzopant/envdrift",
	"version": "1.0.0",
	"description": "CLI that finds keys missing or extra across your .env files — catch config drift between local, staging, and production before it breaks a deploy.",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"main": "dist/index.js",
	"bin": {
		"envdrift": "./dist/index.js"
	},
	"scripts": {
		"dev": "tsx src/index.ts",
		"build": "tsup src/index.ts --format esm --target node22 --clean",
		"start": "node dist/index.js",
		"test": "tsx --test src/**/*.test.ts",
		"typecheck": "tsc --noEmit",
		"release": "node scripts/release.mjs"
	},
	"keywords": [
		"env",
		"dotenv",
		"drift",
		"cli"
	],
	"author": "Lorenzo Pantano",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lorenzopant/envdrift.git"
	},
	"bugs": {
		"url": "https://github.com/lorenzopant/envdrift/issues"
	},
	"homepage": "https://github.com/lorenzopant/envdrift#readme",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^15.0.0",
		"dotenv": "^17.4.2"
	},
	"devDependencies": {
		"@types/node": "^25.9.2",
		"tsup": "^8.5.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	}
}
